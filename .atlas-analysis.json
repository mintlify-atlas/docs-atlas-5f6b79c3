  "keyFeatures": [
    "Modular architecture with multiple Vue 3 frontend applications",
    "Role-based access control with JWT authentication",
    "Beneficiary management system for social programs",
    "Event scheduling and attendance tracking",
    "Citizen participation and course registration",
    "Administrative dashboard with user and permission management",
    "Laravel REST API with Oracle database support",
    "Reusable component library with Tailwind CSS"
