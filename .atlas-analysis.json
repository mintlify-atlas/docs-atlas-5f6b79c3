    "GET /api/programas - Programs management",
    "GET /api/programas/actividades - Activity management",
    "GET /api/eventos - Events listing",
    "GET /api/control-asistencia - Attendance tracking",
    "GET /api/participacion-ciudadana/cursos - Course management",
    "POST /api/participacion-ciudadana/inscripcion - Course enrollment",
    "GET /api/globales/catalogos - Global catalogs",
    "POST /api/globales/export - Data export functionality"
